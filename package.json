{
  "name": "global-claw",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "build": "wrangler deploy --dry-run",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "node scripts/test-integration.mjs",
    "verify:contracts": "node scripts/verify-contracts.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "wrangler types && tsc --noEmit",
    "db:migrate:local": "node scripts/migrate.mjs local",
    "db:migrate:staging": "node scripts/migrate.mjs staging",
    "db:migrate:production": "node scripts/migrate.mjs production"
  },
  "dependencies": {
    "hono": "^4.7",
    "@hono/zod-openapi": "^0.18",
    "drizzle-orm": "^0.38",
    "agents": "^0.7.4",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@cloudflare/vitest-pool-workers": "^0.8",
    "drizzle-kit": "^0.30",
    "typescript": "^5.7",
    "vitest": "^3.1",
    "wrangler": "^4.0"
  }
}
