# Global-Claw Environment Variables
# Copy to .dev.vars for local development (Wrangler reads .dev.vars automatically)
# For staging/production: set via `npx wrangler secret put <KEY> --env <staging|production>`

# ─── Stripe ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-base64-32
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# ─── Telegram ─────────────────────────────────────────
# Per-bot tokens are stored encrypted in D1 (agents.telegram_bot_token_encrypted).
# This secret verifies webhook authenticity (X-Telegram-Bot-Api-Secret-Token header).
TELEGRAM_WEBHOOK_SECRET=generate-random-string-for-webhook-verification

# ─── OAuth Integration Credentials ──────────────────
# Per-provider OAuth app credentials (add as needed when enabling integrations)
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxx
# NOTION_OAUTH_CLIENT_ID=xxx
# NOTION_OAUTH_CLIENT_SECRET=secret_xxx
# Add more providers: {PROVIDER}_CLIENT_ID / {PROVIDER}_CLIENT_SECRET

# ─── LLM Provider API Keys ───────────────────────────
# NOT stored as env vars. Managed via admin dashboard,
# encrypted at rest in D1 llm_providers.api_key_encrypted.
# Only ENCRYPTION_KEY (above) is needed as a runtime secret.

# ─── Cloudflare (for wrangler CLI, not Worker runtime) ─
# CLOUDFLARE_API_TOKEN=xxx
# CLOUDFLARE_ACCOUNT_ID=xxx

# ─── Non-Secret vars (set in wrangler.jsonc vars{}) ──
# ENVIRONMENT=development|staging|production
# APP_URL=http://localhost:8787
# AI_GATEWAY_SLUG=global-claw
